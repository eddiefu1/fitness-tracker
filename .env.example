# Copy this file to `.env` in the project root and fill in values.
# Next.js loads `.env` automatically for local dev.

# FatSecret (optional). If missing—or DISABLE_FATSECRET=1—food search uses Open Food Facts only.
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
# DISABLE_FATSECRET=1

# Daily digest email (Vercel Cron). Prefer Resend — one API key, no Gmail SMTP issues.
# Sign up: https://resend.com — create API key; default "from" works for testing: onboarding@resend.dev
RESEND_API_KEY=
# Optional; default: FitTracker <onboarding@resend.dev>
# RESEND_FROM=FitTracker <onboarding@resend.dev>

# Fallback: Gmail SMTP + App Password (Google Account → Security → App passwords). No spaces around =.
# DAILY_EMAIL_ENABLED=false
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional; defaults to GMAIL_USER
EMAIL_TO=
# Required on Vercel: random string; Vercel Cron sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
# Production URL (links in the email)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Test: npm run email:test

# Withings (weight sync). Register redirect URL: {NEXT_PUBLIC_APP_URL}/api/withings/callback
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# WHOOP (recovery, sleep, workouts, cycles). In WHOOP Developer Dashboard, add every
# redirect URL you use (exact match): https://<your-host>/api/whoop/callback — e.g. production
# and http://localhost:3000/api/whoop/callback for local dev. OAuth uses the site you open in the browser.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Apple Health: Shortcuts / native app POSTs JSON to /api/apple-health/ingest with
# Authorization: Bearer <this secret>. Same secret for GET /api/apple-health/pull from the web app.
APPLE_HEALTH_SYNC_SECRET=

# Server snapshot for Apple Health (free tier: https://upstash.com — create Redis, REST API).
# Required for cloud persistence between phone POST and browser pull.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
